{
  "env": {
    "MCP_TIMEOUT": "60000",
    "MCP_TOOL_TIMEOUT": "30000"
  },
  "permissions": {
    "deny": [
      "Bash(rm -rf *)",
      "Bash(git push --force *)",
      "Read(**/.env)",
      "Write(**/.env)"
    ],
    "defaultMode": "acceptEdits"
  },
  "model": "opus",
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash ~/.claude/hooks/rtk-rewrite.sh"
          }
        ]
      },
      {
        "matcher": "WebFetch",
        "hooks": [
          {
            "type": "command",
            "command": "echo 'WebFetchは使用禁止。Jina MCPを使うこと（mcp__jina__read_url または mcp__jina__search_web）'; exit 2"
          }
        ]
      },
      {
        "matcher": "Read",
        "hooks": [
          {
            "type": "command",
            "command": "bash ~/.claude/hooks/guard-read-size.sh"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash ~/.claude/scripts/post-tool-check.sh"
          }
        ]
      },
      {
        "matcher": "mcp__basic-memory__write_note",
        "hooks": [
          {
            "type": "command",
            "command": "bash ~/.claude/scripts/gdrive-upload.sh"
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash ~/.claude/scripts/setup.sh"
          },
          {
            "type": "command",
            "command": "bash ~/.claude/scripts/gdrive-download.sh"
          },
          {
            "type": "command",
            "command": "bash ~/.claude/scripts/basic-memory-resync.sh"
          },
          {
            "type": "command",
            "command": "bash ~/.claude/scripts/hr-leave-alert.sh"
          },
          {
            "type": "command",
            "command": "bash ~/.claude/scripts/hr-annual-event-alert.sh"
          },
          {
            "type": "command",
            "command": "bash ~/.claude/scripts/hr-law-watch-alert.sh"
          }
        ]
      }
    ],
    "SessionEnd": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash ~/.claude/scripts/gdrive-upload.sh"
          }
        ]
      }
    ],
    "PostCompact": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "echo '[PostCompact] コンテキスト圧縮完了。必要に応じてCLAUDE.mdや作業状況を再確認してください。'"
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash ~/.claude/hooks/run-python.sh ~/.claude/hooks/memo-reminder.py"
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "ccsl",
    "padding": 0
  },
  "enabledPlugins": {
    "claude-mem@thedotmack": false,
    "fakechat@claude-plugins-official": false,
    "discord@claude-plugins-official": true,
    "claude-code-setup@claude-plugins-official": true
  },
  "extraKnownMarketplaces": {
    "thedotmack": {
      "source": {
        "source": "github",
        "repo": "thedotmack/claude-mem"
      }
    }
  },
  "showThinkingSummaries": true,
  "skipDangerousModePermissionPrompt": true,
  "skipAutoPermissionPrompt": true,
  "mcpServers": {
    "basic-memory": {
      "command": "uvx",
      "args": [
        "basic-memory",
        "mcp"
      ],
      "alwaysLoad": true
    }
  },
  "disabledMcpServers": [
    "claude.ai Gmail",
    "claude.ai Google Calendar"
  ]
}
